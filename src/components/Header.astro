---
import { withBase } from '../consts.js';

const NAV = [
  { label: 'Services', path: '/services' },
  { label: 'Work', path: '/work' },
  { label: 'Products', path: '/products' },
  { label: 'About', path: '/about' },
  { label: 'Blog', path: '/blog' },
  { label: 'Contact', path: '/contact' },
];

// Active state is decided from the URL at build time -- no scroll-spy JS.
const current = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (path) => {
  const target = withBase(path).replace(/\/+$/, '');
  return current === target || current.startsWith(`${target}/`);
};
---

<header class="header">
  <div class="container header-container">
    <a href={withBase('/')} class="logo" aria-label="Kiwi Bytes home">
      <img class="logo-mark" src={withBase('kiwi-logo.png')} alt="" width="32" height="32" />
      <span class="logo-kiwi">kiwi</span><span class="logo-bytes">bytes</span><span class="logo-dot">.</span>
    </a>

    <nav class="nav" aria-label="Primary">
      {
        NAV.map(({ label, path }) => (
          <a
            href={withBase(path)}
            class:list={['nav-link', { active: isActive(path) }]}
            aria-current={isActive(path) ? 'page' : undefined}
          >
            {label}
          </a>
        ))
      }
    </nav>

    <button class="theme-toggle" type="button" aria-label="Toggle light/dark theme">
      <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/><line x1="4.93" y1="4.93" x2="6.34" y2="6.34"/><line x1="17.66" y1="17.66" x2="19.07" y2="19.07"/><line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/><line x1="4.93" y1="19.07" x2="6.34" y2="17.66"/><line x1="17.66" y1="6.34" x2="19.07" y2="4.93"/></svg>
      <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>

    <button class="btn btn-primary btn-desktop trigger-project-builder" type="button">
      <span>Launch Project Builder</span>
      <svg class="btn-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </button>

    <button class="mobile-menu-toggle" type="button" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-nav">
      <span class="bar"></span><span class="bar"></span><span class="bar"></span>
    </button>
  </div>
</header>

<div class="mobile-nav-overlay" id="mobile-nav">
  <nav class="mobile-nav" aria-label="Mobile">
    {
      NAV.map(({ label, path }) => (
        <a
          href={withBase(path)}
          class="mobile-nav-link"
          aria-current={isActive(path) ? 'page' : undefined}
        >
          {label}
        </a>
      ))
    }
    <button class="theme-toggle" type="button" aria-label="Toggle light/dark theme" style="margin-top: 1rem;">
      <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/><line x1="4.93" y1="4.93" x2="6.34" y2="6.34"/><line x1="17.66" y1="17.66" x2="19.07" y2="19.07"/><line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/><line x1="4.93" y1="19.07" x2="6.34" y2="17.66"/><line x1="17.66" y1="6.34" x2="19.07" y2="4.93"/></svg>
      <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      <span>Toggle theme</span>
    </button>
    <button class="btn btn-primary trigger-project-builder" type="button" style="margin-top: 1rem;">
      <span>Launch Project Builder</span>
    </button>
  </nav>
</div>
