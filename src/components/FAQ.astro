---
interface Props {
  faqs: { q: string; a: string }[];
  title?: string;
  eyebrow?: string;
}
const { faqs, title = 'Questions, answered.', eyebrow = 'FAQ' } = Astro.props;

// Uses native <details>/<summary>: keyboard-accessible with no JS, and every
// answer stays in the HTML. That matters — answer engines and LLM crawlers
// that don't execute JavaScript can only cite what's in the markup.
---

<section class="faq-section" id="faq">
  <div class="container">
    <div class="section-header reveal-on-scroll">
      <span class="eyebrow">{eyebrow}</span>
      <h2 class="section-title">{title}</h2>
    </div>

    <div class="faq-list reveal-on-scroll">
      {
        faqs.map((faq) => (
          <details class="faq-item">
            <summary class="faq-question">
              <span>{faq.q}</span>
              <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9" />
              </svg>
            </summary>
            <div class="faq-answer">
              <p>{faq.a}</p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
