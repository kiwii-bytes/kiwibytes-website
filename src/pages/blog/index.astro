---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Newsletter from '../../components/Newsletter.astro';
import Icon from '../../components/Icon.astro';
import { withBase } from '../../consts.js';
import { organizationSchema, breadcrumbSchema } from '../../lib/schema.js';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const schema = [
  organizationSchema(),
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Blog', path: '/blog' },
  ]),
];

const dateFmt = new Intl.DateTimeFormat('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
---

<BaseLayout
  title="Blog"
  description="Technical write-ups from Kiwi Bytes on shipping production AI agents, automating operations with n8n and RPA, and scaling Shopify and marketplace commerce systems."
  schema={schema}
>
  <PageHeader
    eyebrow="Writing"
    title="Notes from the build."
    lead="Technical write-ups on what actually works — automating operations, taking AI systems from demo to production, and scaling commerce infrastructure. Written from work we've genuinely done."
  />

  <section class="content-section">
    <div class="container">
      {
        posts.length === 0 ? (
          <p class="empty-state">No posts published yet — the first ones are on the way.</p>
        ) : (
          <div class="blog-grid">
            {posts.map((post) => (
              <a href={withBase(`/blog/${post.id}`)} class="blog-card reveal-on-scroll">
                <div class="blog-card-meta">
                  <time datetime={post.data.publishDate.toISOString()}>
                    {dateFmt.format(post.data.publishDate)}
                  </time>
                </div>
                <h2 class="blog-card-title">{post.data.title}</h2>
                <p class="blog-card-desc">{post.data.description}</p>
                <span class="blog-card-cta">
                  Read <Icon name="arrow" size={15} />
                </span>
                {post.data.tags.length > 0 && (
                  <div class="tag-row">
                    {post.data.tags.map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <Newsletter />
</BaseLayout>
